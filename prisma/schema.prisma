generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum GenerationImageKind {
  INPUT
  OUTPUT
  REFERENCE
}

enum PremiumOrderStatus {
  NEW
  IN_REVIEW
  APPROVED
  DELIVERED
  REJECTED
}

model User {
  id                  String           @id @default(cuid())
  telegramId          String           @unique
  username            String?
  firstName           String?
  lastName            String?
  phone               String?
  language            String           @default("uz")
  role                UserRole         @default(USER)
  avatarUrl           String?
  lastActiveAt        DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  generations         Generation[]
  premiumOrders       PremiumOrder[]
}

model Generation {
  id                  String             @id @default(cuid())
  userId              String
  prompt              String
  customPrompt        String?
  purpose             String
  style               String
  language            String
  ratio               String
  status              GenerationStatus   @default(QUEUED)
  error               String?
  provider            String?
  providerJobId       String?
  outputImagePath     String?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  images              GenerationImage[]
}

model GenerationImage {
  id                  String              @id @default(cuid())
  generationId        String
  kind                GenerationImageKind
  path                String
  mimeType            String?
  sizeBytes           Int?
  width               Int?
  height              Int?
  createdAt           DateTime            @default(now())
  generation          Generation          @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id                  String           @id @default(cuid())
  slug                String           @unique
  title               String
  description         String
  prompt              String
  category            String
  language            String           @default("en")
  purpose             String
  style               String
  ratio               String
  isActive            Boolean          @default(true)
  sortOrder           Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model PremiumOrder {
  id                  String              @id @default(cuid())
  userId              String
  title               String
  description         String
  deadline            DateTime?
  telegramUsername    String?
  contact             String
  status              PremiumOrderStatus  @default(NEW)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceImages     PremiumOrderImage[]
}

model PremiumOrderImage {
  id                  String           @id @default(cuid())
  premiumOrderId      String
  path                String
  mimeType            String?
  createdAt           DateTime         @default(now())
  premiumOrder        PremiumOrder     @relation(fields: [premiumOrderId], references: [id], onDelete: Cascade)
}

model AdminSetting {
  id                  String           @id @default(cuid())
  key                 String           @unique
  value               Json
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model Announcement {
  id                  String           @id @default(cuid())
  title               String
  body                String
  language            String           @default("uz")
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}
